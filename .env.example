# 本地 Dify 默认常见地址；如果你的 Dify 端口不是 80，请改成例如 http://127.0.0.1:8080/v1
DIFY_API_BASE_URL=http://127.0.0.1/v1
# Docker 容器访问宿主机 Dify 时使用；不要写 127.0.0.1
DOCKER_DIFY_API_BASE_URL=http://host.docker.internal/v1
DIFY_API_KEY=app-your-dify-chatflow-api-key
DIFY_APP_TYPE=chatflow
DIFY_USER=dealer-demo

# 如果以后要切回 Workflow，再改成：
# DIFY_APP_TYPE=workflow
# DIFY_WORKFLOW_ID=

# AI 导购语音播报：和白龙马一样由后端调用 TTS 模型，前端播放返回的 mp3 流
# 硅基流动 TTS
TTS_PROVIDER=siliconflow
TTS_VOICE_ID=FunAudioLLM/CosyVoice2-0.5B:claire
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B

# 豆包/方舟语音合成，客服女声默认 zh_female_kefunvsheng_uranus_bigtts
# TTS_PROVIDER=doubao
# TTS_VOICE_ID=zh_female_kefunvsheng_uranus_bigtts
DOUBAO_ACCESS_KEY=
DOUBAO_API_KEY=
DOUBAO_APP_ID=
DOUBAO_RESOURCE_ID=

# 也可以切 OpenAI TTS
# TTS_PROVIDER=openai
# TTS_VOICE_ID=nova
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com
